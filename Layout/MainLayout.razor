@inherits LayoutComponentBase
<style>
    .header {
        position: relative;
        z-index: 1;
        overflow: hidden;
    }

        .header:before, .header:after {
            position: absolute;
            top: 51%;
            overflow: hidden;
            width: 50%;
            height: 1px;
            content: '\a0';
            background-color: @Constants.ColorScheme["Text"];
        }

        .header:before {
            margin-left: -50%;
            text-align: right;
        }

    div, span, h1, h2, h3, h4, h5, button {
        font-family: Dosis;
        color: @Text;
    }
</style>
<NavMenu />

<main>
    <div style="background-image:linear-gradient(@Main,@Main);">
        <CascadingValue Value="ButtonText" Name="ButtonText">
            <CascadingValue Value="Text" Name="Text">
                <CascadingValue Value="Accent" Name="Accent">
                    <CascadingValue Value="Main" Name="Main">
                        @Body
                    </CascadingValue>
                </CascadingValue>
            </CascadingValue>
        </CascadingValue>
    </div>
</main>
<Footer @bind-Main=@Main @bind-Accent=@Accent @bind-Text=@Text @bind-ButtonText=ButtonText />

@code
{
    string Main { get; set; } = Constants.ColorScheme["Main"];
    string Accent { get; set; } = Constants.ColorScheme["Accent"];
    string Text { get; set; } = Constants.ColorScheme["Text"];
    string ButtonText { get; set; } = Constants.ColorScheme["ButtonText"];
}

